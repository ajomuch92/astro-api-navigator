{
  "name": "astro-api-navigator",
  "displayName": "Astro API Navigator",
  "description": "Ctrl+Click on any API call to jump directly to the handler in your Astro project (pages/api)",
  "version": "0.1.0",
  "publisher": "ajomuch92",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "astro",
    "api",
    "navigation",
    "go-to-definition",
    "fetch"
  ],
  "activationEvents": [
    "workspaceContains:astro.config.*",
    "workspaceContains:src/pages/api/**"
  ],
  "main": "./dist/extension.js",
  "icon": "images/icon.png",
  "contributes": {
    "configuration": {
      "title": "Astro API Navigator",
      "properties": {
        "astroApiNavigator.pagesDir": {
          "type": "string",
          "default": "src/pages",
          "description": "Relative path to the Astro pages directory from the workspace root"
        },
        "astroApiNavigator.apiPatterns": {
          "type": "array",
          "default": [
            "fetch\\(['\"`]({apiPath}[^'\"`?#]*)",
            "\\$fetch\\(['\"`]({apiPath}[^'\"`?#]*)",
            "axios\\.(?:get|post|put|patch|delete|head)\\(['\"`]({apiPath}[^'\"`?#]*)",
            "axios\\(\\{[^}]*url:\\s*['\"`]({apiPath}[^'\"`?#]*)",
            "useFetch\\(['\"`]({apiPath}[^'\"`?#]*)",
            "useAsyncData\\([^,]+,\\s*\\(\\)\\s*=>\\s*\\$?fetch\\(['\"`]({apiPath}[^'\"`?#]*)"
          ],
          "description": "Regex patterns to detect API calls. Use {apiPath} as placeholder for the captured group."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
